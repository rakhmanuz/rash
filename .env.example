# Google Sheets - qarzdorlik (debt) Apps Script URL
# To'lovlar sahifasida o'quvchi ID orqali jadvaldan qarzdorlik olinadi
SHEET_DEBT_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Monitor panel (/monitor) — bitta login/parol bilan kirish (katta ekran)
# Parolni o'zgartiring
MONITOR_LOGIN=monitor
MONITOR_PASSWORD=monitor123

# Evalbee → Settings → Sync API (POST webhook)
# Evalbee URL: https://SIZNING_DOMEN/api/integrations/evalbee
EVALBEE_HS256_SECRET=
# Agar kalit base64 (binary) bo‘lsa: true yoki 1
# EVALBEE_SECRET_IS_BASE64=true

# OpenAI integratsiyasi (AI tekshiruv bo'limi)
OPENAI_API_KEY=
# AI tekshiruv uchun model (masalan: gpt-5.4)
OPENAI_SCORING_MODEL=gpt-5.4
# AI tekshiruv uchun rasm URL larini absolut qilish (masalan: https://rash.uz)
PUBLIC_APP_URL=

# --- TWA / Google Play (rash.uz mobil ilova) ---
# Sayt: https://rash.uz/.well-known/assetlinks.json
# Bubblewrap: https://github.com/GoogleChromeLabs/bubblewrap
# Paket nomi Bubblewrap init da tanlangan applicationId bilan bir xil bo‘lsin.
ANDROID_TWA_PACKAGE_NAME=uz.rash.app
# SHA-256 (bir yoki bir nechta): Play Console → Release → Setup → App integrity
# yoki: keytool -list -v -keystore YOUR.keystore -alias YOUR_ALIAS
# Qo‘shimcha probellar yo‘q, vergul yoki yangi qator bilan ajrating. 64 ta hex ham ishlaydi.
ANDROID_TWA_SHA256_CERT_FINGERPRINTS=

# Play Console "Maxfiylik siyosati" URL (saytda tayyor: /privacy)
# PLAY_PRIVACY_URL=https://rash.uz/privacy

# TWA manifest generatsiyasi (npm run twa:sync-manifest)
# GitHub Actions: "TWA Android build" → Run workflow → unsigned yoki signed
# Imzolangan artifact uchun repo Secrets (GitHub UI — .env ga yozilmaydi):
#   TWA_ANDROID_KEYSTORE_BASE64  — npm run twa:secret-b64 -- android.keystore
#   TWA_KEYSTORE_PASSWORD
#   TWA_KEY_PASSWORD
# TWA_WEB_MANIFEST_URL=https://rash.uz/manifest.json
# Web Push / bildirishnomalar kerak bo'lsa: 1
# TWA_ENABLE_NOTIFICATIONS=1

# --- Capacitor (mobile-app/, APK uchun) ---
# npm run mobile:help
# Tayyor imzolangan AAB + APK: npm run mobile:release → output/rash-play-release.{aab,apk}
# Faqat AAB: npm run mobile:bundle | faqat APK: npm run mobile:apk
# Parol va .jks: mobile-app/PLAY_SIGNING_BACKUP.txt (repoga commit qilinmaydi)
# Emulyator + lokal Next: mobile-app/capacitor.config.json ichida server.url = "http://10.0.2.2:3000"
