# Google Sheets - qarzdorlik (debt) Apps Script URL
# To'lovlar sahifasida o'quvchi ID orqali jadvaldan qarzdorlik olinadi
SHEET_DEBT_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Monitor panel (/monitor) — bitta login/parol bilan kirish (katta ekran)
# Parolni o'zgartiring
MONITOR_LOGIN=monitor
MONITOR_PASSWORD=monitor123
