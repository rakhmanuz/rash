    "twa:help": "node -e \"console.log(['TWA / Google Play:','  GitHub Actions → TWA Android build → Run workflow','    build_mode: unsigned | signed (signed = 3 ta repo secret, workflow faylida ro‘yxat)','  Keystore → base64: npm run twa:secret-b64 -- path/to/android.keystore','  Lokal: npm run twa:config-local → twa:sync-manifest → twa:update → twa:build / twa:build:unsigned','  Eski: scripts/twa/setup.ps1 / setup.sh','  Server .env: ANDROID_TWA_PACKAGE_NAME, ANDROID_TWA_SHA256_CERT_FINGERPRINTS','  https://rash.uz/.well-known/assetlinks.json','  https://rash.uz/privacy'].join(String.fromCharCode(10)))\""
